# Real test configuration for pi-web-search
# Copy this file to .env and replace the placeholder values with models/extensions
# available in your local pi environment.

# Optional: alternate pi binary
PI_BIN=pi

# The plugin under test. Usually keep this as-is.
PI_WEB_SEARCH_EXTENSION=./src/index.ts

# Optional extra provider extensions, comma-separated.
# Example: /path/to/provider-extension.ts,/another/provider-extension.ts
PI_PROVIDER_EXTENSIONS=/path/to/provider-extension.ts

# Real web_search models: one model per family you want to verify.
PI_WEB_SEARCH_MODEL_OPENAI=provider/model-openai
PI_WEB_SEARCH_MODEL_ANTHROPIC=provider/model-anthropic
PI_WEB_SEARCH_MODEL_GOOGLE=provider/model-google

# Optional override prompt for real web_search verification.
PI_WEB_SEARCH_PROMPT=必须调用 web_search 搜索：OpenAI Responses API web search tool citations。回答里列出主要 URL。

# Gemini-only real url_context verification model.
PI_URL_CONTEXT_MODEL=provider/model-google
PI_URL_CONTEXT_PROMPT=请调用 url_context，总结这个 URL 的核心内容：https://developers.openai.com/api/docs/guides/tools-web-search，并列出来源。
